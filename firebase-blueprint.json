{
  "entities": {
    "Brief": {
      "title": "Brief",
      "description": "AI-generated creative brand briefs saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "brandName": { "type": "string" },
        "brandDescription": { "type": "string" },
        "creativeConcept": { "type": "string" },
        "colors": { "type": "array" },
        "typography": { "type": "string" },
        "strategy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "brandName", "creativeConcept", "colors", "createdAt"]
    },
    "FeedbackPin": {
      "title": "FeedbackPin",
      "description": "Comment pins placed on agency project portfolio layouts in the interactive client workspace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "userId", "userEmail", "x", "y", "text", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Real-time communication dispatches between client and design agency partners.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "author": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "agency"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "author", "text", "role", "createdAt"]
    }
  },
  "firestore": {
    "briefs/{briefId}": {
      "schema": "Brief",
      "description": "User saved brand aesthetic architectures generated by the integrated Gemini engine."
    },
    "feedbackPins/{pinId}": {
      "schema": "FeedbackPin",
      "description": "Interactive feedback pins annotated directly onto project image assets."
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Live, real-time message stream synced across client and agency workspaces."
    }
  }
}
